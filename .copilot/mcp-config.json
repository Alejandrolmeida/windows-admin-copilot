{
  "mcpServers": {

    "powershell-mcp": {
      "command": "C:\\Program Files\\PowerShell\\Modules\\PowerShell.MCP\\1.7.6\\bin\\win-x64\\PowerShell.MCP.Proxy.exe",
      "args": [],
      "description": "PowerShell.MCP - Acceso a 10,000+ módulos PSGallery. Gestión completa de Windows local/remoto."
    },

    "win-cli-mcp": {
      "command": "node",
      "args": [
        "C:\\mcp-servers\\win-cli-mcp-server\\dist\\index.js",
        "--config",
        "C:\\mcp-servers\\win-cli-mcp-server\\config.json"
      ],
      "description": "win-cli-mcp-server - PowerShell, CMD, Git Bash y SSH a servidores remotos."
    },

    "windows-admin-mcp": {
      "command": "C:\\Users\\%USERNAME%\\miniconda3\\python.exe",
      "args": [
        "C:\\mcp-servers\\windows-admin-mcp\\windows_admin_server.py"
      ],
      "description": "windows-admin-mcp - WinRM/SSH: diagnóstico, servicios, métricas, Event Logs."
    },

    "azure-mcp": {
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"],
      "description": "Azure MCP oficial (Microsoft) - Gestión de VMs, Storage, SQL Azure, Resource Groups, etc.",
      "env": {
        "AZURE_SUBSCRIPTION_ID": "",
        "AZURE_TENANT_ID": "",
        "AZURE_CLIENT_ID": "",
        "AZURE_CLIENT_SECRET": ""
      }
    },

    "vmware-vsphere-mcp": {
      "command": "C:\\Users\\%USERNAME%\\miniconda3\\python.exe",
      "args": [
        "C:\\mcp-servers\\vmware-vsphere-mcp-server\\run_server_stdio.py"
      ],
      "description": "VMware vSphere MCP - Gestión de VMs, snapshots, clones, redes y almacenamiento vCenter.",
      "env": {
        "VCENTER_HOST": "",
        "VCENTER_USER": "administrator@vsphere.local",
        "VCENTER_PASSWORD": "",
        "VCENTER_PORT": "443",
        "VCENTER_SSL_VERIFY": "false"
      }
    },

    "hyper-v": {
      "_note": "Hyper-V se gestiona via powershell-mcp con el módulo nativo Hyper-V de Windows.",
      "_examples": [
        "Get-VM | Select Name, State, MemoryAssigned",
        "Start-VM -Name 'NombreVM'",
        "Stop-VM -Name 'NombreVM' -Force",
        "Checkpoint-VM -Name 'NombreVM' -SnapshotName 'pre-cambio'",
        "Get-VMSnapshot -VMName 'NombreVM'"
      ]
    },

    "virtualbox": {
      "_note": "VirtualBox se gestiona via win-cli-mcp usando VBoxManage CLI.",
      "_examples": [
        "VBoxManage list vms",
        "VBoxManage list runningvms",
        "VBoxManage startvm 'NombreVM' --type headless",
        "VBoxManage controlvm 'NombreVM' savestate",
        "VBoxManage snapshot 'NombreVM' take 'pre-cambio'"
      ]
    }

  }
}
