# Secrets / credenciales
.env
*.env.*
secrets.json

# Carpeta de configuración local — credenciales, relay keys, registros de servidores
# NUNCA commitear — contiene passwords y connection strings
.config/

# Contraseñas en config local
mcp-config.local.json

# MCP Memory — datos personales, no compartir en el repo
memory.json

# Logs
*.log
logs/

# Node
node_modules/
dist/
.npm/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Archivos generados con secrets de Azure Relay (NO commitear)
client-*.yml
server-relay.yml
server-registry.json
output/

# Datos de monitorización SQL — contienen métricas del cliente (NUNCA commitear)
docs/data/

# Informes Word — contienen datos del cliente, nombres de servidor, logins SQL (NUNCA commitear a repo público)
docs/*.docx

# Lock files de Word
docs/~$*.docx

# Scripts con datos de cliente hardcodeados
docs/gen_migration_report.py

# Carpeta de clientes — documentos, scripts y datos CONFIDENCIALES (NUNCA commitear)
customers/*
!customers/.gitkeep
